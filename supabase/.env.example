# ============================================================
# Supabase Self-Hosted Environment Variables
# Copy this to .env and fill in all values
# ============================================================

# ─── PostgreSQL ───────────────────────────────────────────────
POSTGRES_PASSWORD=your-super-secret-postgres-password
POSTGRES_PORT=5432

# ─── JWT ──────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-token-at-least-32-chars

# ─── API / URLs ───────────────────────────────────────────────
# External URL where Kong is accessible (your VPS domain)
API_EXTERNAL_URL=http://your-domain.com:8000
SITE_URL=http://your-domain.com:3001
ADDITIONAL_REDIRECT_URLS=["habits://auth/callback","http://localhost:8090"]

# ─── Kong ─────────────────────────────────────────────────────
KONG_HTTP_PORT=8000

# ─── Supabase Keys ───────────────────────────────────────────
# Generate these using JWT_SECRET at https://supabase.com/docs/guides/self-hosting#api-keys
ANON_KEY=your-anon-key
SERVICE_ROLE_KEY=your-service-role-key

# ─── Google OAuth ─────────────────────────────────────────────
# Create at https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ─── Realtime ─────────────────────────────────────────────────
# Generate with: openssl rand -base64 48
SECRET_KEY_BASE=your-secret-key-base-at-least-64-chars
