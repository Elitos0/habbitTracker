# ─── App (Expo) ───────────────────────────────────────────────
EXPO_PUBLIC_SUPABASE_URL=http://your-domain.com:8000
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
EXPO_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# ─── Docker Compose ───────────────────────────────────────────
WEB_PORT=3000
KONG_HTTP_PORT=8000
STUDIO_PORT=3001
POSTGRES_PORT=5432

# ─── PostgreSQL ───────────────────────────────────────────────
POSTGRES_PASSWORD=your-super-secret-postgres-password

# ─── JWT (generate: openssl rand -base64 32) ─────────────────
JWT_SECRET=your-super-secret-jwt-token-at-least-32-chars

# ─── API / URLs ───────────────────────────────────────────────
API_EXTERNAL_URL=http://your-domain.com:8000
SITE_URL=http://your-domain.com:3000
ADDITIONAL_REDIRECT_URLS=["habits://auth/callback","http://localhost:3000"]

# ─── Supabase Keys ───────────────────────────────────────────
# Generate at https://supabase.com/docs/guides/self-hosting#api-keys
ANON_KEY=your-anon-key
SERVICE_ROLE_KEY=your-service-role-key

# ─── Google OAuth ─────────────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ─── Realtime ─────────────────────────────────────────────────
# Generate: openssl rand -base64 48
SECRET_KEY_BASE=your-secret-key-base-at-least-64-chars
